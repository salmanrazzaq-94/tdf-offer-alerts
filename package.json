{
  "name": "tdf-offer-alerts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram and Cloudflare Worker bot for checking TDF offers.",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit false",
    "check": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.worker.json && tsc -p tsconfig.worker-test.json && tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "knip": "knip",
    "test:compiled": "node --test dist/test/*.test.js",
    "test": "npm run build && npm run test:compiled",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-exclude='dist/test/**/*.js' --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=90 dist/test/*.test.js",
    "quality": "npm run typecheck && npm run lint && npm run knip && npm run test:coverage && npm run worker:dry-run",
    "smoke:worker": "node scripts/smoke-worker.mjs",
    "login:local": "npm run build && node --env-file=.env dist/src/login-local.js",
    "login:browserbase": "npm run build && node --env-file=.env dist/src/login-browserbase.js",
    "install-browser": "playwright install chromium",
    "worker:dry-run": "wrangler deploy --dry-run",
    "worker:e2e-deploy": "wrangler deploy --config wrangler.e2e.toml",
    "worker:e2e": "npm run build && node scripts/worker-e2e.mjs",
    "worker:deploy": "node scripts/ensure-production-deploy-from-main.mjs && wrangler deploy"
  },
  "dependencies": {
    "@browserbasehq/sdk": "^2.12.0",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260526.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "knip": "^6.14.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "wrangler": "^4.95.0"
  },
  "engines": {
    "node": ">=22"
  }
}
