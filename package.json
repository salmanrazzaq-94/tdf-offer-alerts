{
  "name": "tdf-offer-alerts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitHub Action that checks TDF offers and sends Telegram alerts for newly seen performances.",
  "scripts": {
    "build": "tsc --noEmit false",
    "check": "tsc --noEmit",
    "test": "tsc --noEmit false && node --test dist/test/*.test.js",
    "start": "node dist/src/check-tdf.js",
    "start:local": "tsc --noEmit false && node --env-file=.env dist/src/check-tdf.js",
    "send-current": "node dist/src/send-current.js",
    "send-current:local": "tsc --noEmit false && node --env-file=.env dist/src/send-current.js",
    "telegram-commands": "node dist/src/telegram-commands.js",
    "telegram-commands:local": "tsc --noEmit false && node --env-file=.env dist/src/telegram-commands.js",
    "login:local": "tsc --noEmit false && node --env-file=.env dist/src/login-local.js",
    "install-browser": "playwright install chromium",
    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260523.1",
    "@types/node": "^22.10.0",
    "typescript": "^5.9.0",
    "wrangler": "^4.94.0"
  },
  "engines": {
    "node": ">=22"
  }
}
